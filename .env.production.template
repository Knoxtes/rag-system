# ============================================
# RAG Chat System - Production Environment Template
# ============================================
# 
# DEPLOYMENT INSTRUCTIONS:
# 1. Copy this file: cp .env.production.template .env.production
# 2. Fill in your actual values below
# 3. Ensure file permissions: chmod 600 .env.production
# ============================================

# ----- Flask Configuration -----
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_ENV=production
FLASK_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# ----- CORS Settings -----
# Comma-separated list of allowed origins (your frontend URL)
CORS_ORIGINS=https://ask.yourdomain.com,https://www.yourdomain.com

# ----- Google Cloud Configuration -----
# Your Google Cloud project ID (for Vertex AI)
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# ----- Google OAuth (User Authentication) -----
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ----- Admin Access Control -----
# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@yourdomain.com,backup-admin@yourdomain.com

# ----- Google Drive OAuth (For Indexing) -----
# Callback URL for Drive authentication (must match credentials.json)
GDRIVE_REDIRECT_URI=https://ask.yourdomain.com/admin/gdrive/callback

# ----- Rate Limiting -----
# Optional: Redis URL for distributed rate limiting
# Leave empty to use in-memory (fine for single instance)
# REDIS_URL=redis://localhost:6379/0

# ----- Scheduled Sync Settings -----
# Read by scheduler.py as defaults (CLI flags override).
# SYNC_TIME: time of day the sync runs (HH:MM, 24-hour, UTC)
# SYNC_INTERVAL_DAYS: run every N days (e.g., 3 = check for changed
#   documents every third day). With a daily cron entry running
#   "scheduler.py --once", runs inside the interval are skipped.
SYNC_TIME=00:00
SYNC_INTERVAL_DAYS=3

# Optional: Webhook URL for sync notifications (Slack, Discord, etc.)
# SYNC_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ----- AI/Embedding Settings -----
# NOTE: USE_VERTEX_AI, USE_VERTEX_EMBEDDINGS, CHROMA_PERSIST_DIR, CREDENTIALS_FILE,
# and TOKEN_FILE are currently hardcoded in config.py — setting them here has no effect.
# Edit config.py directly to change these values.
